# 카카오맵 JavaScript SDK 앱 키 (클라이언트 노출 OK — 도메인 제한 설정 필수)
NEXT_PUBLIC_KAKAO_APP_KEY=your_kakao_javascript_key

# ODsay API 키 (서버에서만 사용 — 클라이언트 노출 금지)
ODSAY_API_KEY=your_odsay_api_key

# Firebase (클라이언트에서 직접 Realtime DB 구독)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ODsay 콘솔에 등록한 도메인 — 웹 키 Referer 검증용 (미설정 시 http://localhost:3003)
ODSAY_REFERER=http://localhost:3003

# 카카오 REST API 키 (developers.kakao.com 같은 앱) — 택시 실경로용, 미설정 시 점선 표시
KAKAO_REST_API_KEY=
